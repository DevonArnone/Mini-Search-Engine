DATABASE_URL=postgresql://mini_search:mini_search@localhost:5432/mini_search
MEILI_HOST=http://localhost:7700
MEILI_MASTER_KEY=mini_search_master_key
SEARCH_DEMO_MODE=false
SEARCH_TIMEOUT_MS=4000
DATABASE_TIMEOUT_MS=5000

# Crawler settings
CRAWLER_USER_AGENT=MiniSearchBot/1.0 (+https://github.com/DevonArnone/Mini-Search-Engine)
CRAWLER_MAX_DEPTH=3
CRAWLER_CONCURRENCY=5
CRAWLER_RATE_LIMIT_PER_DOMAIN_MS=1000
CRAWLER_MAX_RETRIES=3
# Set to true ONLY for local development — never in production
CRAWLER_IGNORE_ROBOTS=false
MEILI_TASK_TIMEOUT_MS=30000

# Source registry — controls which docs sites are crawled
SEED_CONFIG_PATH=services/crawler/seeds/docs_sources.yaml
